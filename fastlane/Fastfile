default_platform(:ios)

platform :ios do
  desc "Invia una build già elaborata alla revisione App Store"
  lane :submit_app_store do |options|
    version = options[:version].to_s
    build_number = options[:build_number].to_s

    UI.user_error!("Manca version:<x.y.z>") if version.empty?
    UI.user_error!("Manca build_number:<numero>") if build_number.empty?

    key_id = ENV.fetch("APP_STORE_CONNECT_KEY_ID")
    issuer_id = ENV.fetch("APP_STORE_CONNECT_ISSUER_ID")
    key_path = ENV.fetch(
      "APP_STORE_CONNECT_KEY_PATH",
      File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8")
    )

    UI.user_error!("Chiave App Store Connect non trovata: #{key_path}") unless File.file?(key_path)

    # Sta ciave ga el ruolo App Manager: niente login Apple ID o codici 2FA.
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path
    )

    deliver(
      api_key: api_key,
      app_identifier: "it.meska.rubricaassociati",
      app_version: version,
      build_number: build_number,
      metadata_path: File.expand_path("app_store/metadata", Dir.pwd),
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: true,
      # Se Apple sta ancora valutando la release precedente, la nova la sostituise.
      reject_if_possible: true,
      automatic_release: true,
      force: true,
      run_precheck_before_submit: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false
      }
    )
  end
end
